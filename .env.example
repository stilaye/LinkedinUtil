# ── Auth mode (choose ONE) ────────────────────────────────────────────────────

# Option 1 (recommended): reuse your existing Chrome login — no password needed
# Close Chrome before running, then set:
CHROME_PROFILE=true

# Optional: override Chrome profile path (default is macOS Chrome location)
# CHROME_PROFILE_DIR=/Users/you/Library/Application Support/Google/Chrome

# Option 2: credential login (used when CHROME_PROFILE is not set)
LI_EMAIL=your_linkedin_email@example.com
LI_PASSWORD=your_linkedin_password

# ── Optional ──────────────────────────────────────────────────────────────────
# Claude API key — only needed if use_ai_outreach=true in config.json
ANTHROPIC_API_KEY=sk-ant-...
